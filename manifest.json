{
  "manifest_version": 3,
  "name": "Shukatsu MyPage Autofill",
  "description": "Autofill Japanese recruiting mypage registration forms from a locally saved profile.",
  "version": "0.14.8",
  "permissions": ["activeTab", "debugger", "scripting", "storage", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_title": "Shukatsu Autofill",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
